{
  "name": "kigali-tech-store",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Kigali Tech Store — Vue 3 e-commerce SPA with Stripe payments and Express backend",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "start": "concurrently -n frontend,backend -c cyan,yellow \"vite\" \"node server/index.js\"",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@stripe/stripe-js": "^4.10.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pinia": "^2.3.0",
    "stripe": "^17.7.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-vue": "^6.0.0",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.6.3",
    "vite": "^7.3.2",
    "vue-tsc": "^2.2.0"
  }
}

